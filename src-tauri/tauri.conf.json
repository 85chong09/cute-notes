{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "com.cute-notes.app",
  "productName": "可爱便签",
  "version": "1.0.0",
  "build": {
    "beforeDevCommand": "cd ../ && python server.py",
    "beforeBuildCommand": "",
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "decorations": false,
        "resizable": true,
        "width": 480,
        "height": 550,
        "minWidth": 480,
        "minHeight": 520,
        "alwaysOnTop": true,
        "center": true,
        "title": "可爱便签",
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "longDescription": "可爱便签 - 一个功能丰富的待办事项应用，支持标签、重复任务、密码保护等功能。",
    "shortDescription": "可爱便签",
    "targets": "all"
  },
  "plugins": {
    "dialog": {
      "all": true,
      "ask": true,
      "confirm": true,
      "message": true,
      "open": true,
      "save": true
    },
    "shell": {
      "open": true
    }
  }
}
